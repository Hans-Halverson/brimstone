[BytecodeFunction: prefixIncHazard] {
  Parameters: 1, Registers: 2
     0: Mov r0, a0
     3: Mov r1, a0
     6: ToNumeric r1, r1
     9: Inc r1
    11: Mov a0, r1
    14: Add r0, r0, r1
    18: Ret r0
}

