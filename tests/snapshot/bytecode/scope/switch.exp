    21: StrictEqual r3, r2, r3, ic1
    26: JumpTrue r3, 27 (.L1)
    29: LoadImmediate r3, 3
    32: StrictEqual r3, r2, r3, ic2
    37: JumpTrue r3, 18 (.L2)
    40: Jump 17 (.L3)
  .L0:
