    45: CheckTdz r1, c1
    48: Add r2, r0, r1, ic3
  .L1:
    53: LoadTrue r0
  .L2:
    55: LoadFalse r1
  .L3:
    57: LoadUndefined r2
    59: Ret r2
  Constant Table:
    0: [String: x]
    1: [String: y]
}

