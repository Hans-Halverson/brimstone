[BytecodeFunction: simpleAssignHazard] {
  Parameters: 1, Registers: 1
     0: Mov r0, a0
     3: LoadImmediate a0, 2
     6: Add r0, r0, a0
    10: Ret r0
}

[BytecodeFunction: inOuterExpr] {
