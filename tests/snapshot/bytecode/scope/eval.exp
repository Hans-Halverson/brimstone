     70: Call r0, r0, r1, 1
     75: Jump 4 (.L2)
  .L1:
     77: LoadUndefined r0
  .L2:
     79: LoadGlobal r0, c0, k5
     83: JumpNullish r0, 13 (.L3)
     86: LoadConstant r1, c4
     89: Call r0, r0, r1, 1
     94: Jump 4 (.L4)
  .L3:
     96: LoadUndefined r0
  .L4:
     98: LoadUndefined r0
    100: Ret r0
  Constant Table:
    0: [String: eval]
    1: [String: x; const x = 1]
    2: [String: const x = 1; function inner() { x }]
    3: [String: eval('')]
    4: [String: "use strict"; eval('')]
  Exception Handlers:
    3-16 -> 18
}

