[BytecodeFunction: <global>] {
  Parameters: 0, Registers: 2
     0: NewClosure r0, c0
     3: StoreGlobal r0, c1
     6: LoadGlobal r0, c1
     9: LoadImmediate r1, 20
    12: Call r0, r0, r1, 1
    17: LoadUndefined r0
    19: Ret r0
  Constant Table:
    0: [BytecodeFunction: fib]
    1: [String: fib]
}

[BytecodeFunction: fib] {
  Parameters: 1, Registers: 3
     0: LoadImmediate r0, 2
     3: LessThan r0, a0, r0
     7: JumpFalse r0, 8 (.L0)
    10: LoadImmediate r0, 1
    13: Ret r0
  .L0:
    15: LoadGlobal r0, c0
    18: LoadImmediate r1, 1
    21: Sub r1, a0, r1, ic0
    26: Call r0, r0, r1, 1
    31: LoadGlobal r1, c0
    34: LoadImmediate r2, 2
    37: Sub r2, a0, r2, ic1
    42: Call r1, r1, r2, 1
    47: Add r0, r0, r1, ic2
    52: Ret r0
  Constant Table:
    0: [String: fib]
}
